# claude-watch-anywhere — bridge config. Copy to `.env` (which is gitignored).
#
#   cp .env.example .env   # then fill in your relay values
#
# Relay = digits-only pairing from any network. Leave RELAY blank for LAN-only.
CLAUDE_WATCH_RELAY=https://claude-watch-relay.YOU.workers.dev
CLAUDE_WATCH_RELAY_SECRET=your-shared-secret

# Spawn a free cloudflared quick tunnel automatically (1=yes, needs cloudflared on PATH).
CLAUDE_WATCH_TUNNEL=1

# ...or pin a fixed public URL instead of spawning cloudflared (then omit TUNNEL above):
# CLAUDE_WATCH_TUNNEL_URL=https://your-fixed-host.ts.net

# Plugin monitor behavior (keep these for the auto-started bridge):
CLAUDE_WATCH_QUIET=1     # only the pairing line + warnings, not every event
CLAUDE_WATCH_SINGLE=1    # if a bridge is already running, extra sessions don't start another
